# ══════════════════════════════════════════════════════════════════
#  AI Web Automation — Environment Variables
# ══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# All services used are FREE TIER — no paid subscriptions needed.

# ── Google Gemini AI ─────────────────────────────────────────────
# Get free key: https://aistudio.google.com/app/apikey
# FREE TIER LIMITS: 1,500 requests/day, 15 requests/minute
# The system enforces 1,450/day (safety margin) and 14 RPM.
# Quota resets at midnight in the configured TIMEZONE.
# Troubleshooting: If you get "quota exhausted", check /health endpoint
#   → gemini_quota.daily_remaining shows how many calls remain.
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Sheets ────────────────────────────────────────────────
# The spreadsheet ID from its URL: docs.google.com/spreadsheets/d/{THIS_ID}/edit
# FREE TIER LIMITS: 300 read requests/min, 60 write requests/min per user
# If quota is exceeded, data is saved to data/local_fallback/ and auto-synced later.
# OAuth credentials go in: config/credentials/oauth_credentials.json
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# ── WhatsApp Mode ─────────────────────────────────────────────────
# Options: "meta_cloud" (recommended) or "whatsapp_web_js" (requires Node.js)
# meta_cloud: Uses official Meta Cloud API — most reliable
# whatsapp_web_js: Uses whatsapp-web.js via Node.js bridge — no Meta account needed
WHATSAPP_MODE=meta_cloud

# ── Meta WhatsApp Cloud API (Option A) ────────────────────────────
# Setup guide: https://developers.facebook.com/docs/whatsapp/cloud-api/
# FREE TIER: 1,000 service conversations/month (~33/day)
# These are required if WHATSAPP_MODE=meta_cloud:
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=your_custom_verify_token
# Required for webhook signature verification (security)
# Find it: Facebook App Dashboard → Settings → Basic → App Secret
META_APP_SECRET=

# ── Telegram Admin Alerts ─────────────────────────────────────────
# Create a bot via @BotFather, then get your chat ID from @userinfobot
# FREE TIER: Unlimited messages (Telegram Bot API is free)
# These are optional — if not set, admin alerts are logged but not sent.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Business Config ──────────────────────────────────────────────
# These values are used in WhatsApp templates and outreach messages
COMPANY_NAME=YourCompany
AGENT_NAME=Priya
PORTFOLIO_URL=https://yourwebsite.com
UPI_ID=name@upi

# ── Scraper Config ───────────────────────────────────────────────
# Comma-separated lists of target cities and business types
TARGET_CITIES=Delhi,Mumbai,Pune
BUSINESS_TYPES=Restaurant,Clinic,Salon,Gym,Retail

# Hour (24h format, IST) to run the daily scraper (default: 6 AM)
SCRAPE_SCHEDULE_HOUR=6

# Maximum cold WhatsApp messages per day (stay within free-tier limits!)
# Recommended: 12-20 for meta_cloud, 30-50 for whatsapp_web_js
# ⚠️  Exceeding ~33/day on meta_cloud will exhaust free conversations
MAX_COLD_MESSAGES_PER_DAY=12

# ── WhatsApp-web.js Node Server (Option B only) ──────────────────
# URL of the Node.js whatsapp-web.js server
# Start it with: cd phase2_whatsapp/whatsapp_web_js && npm install && npm start
WHATSAPP_WEB_JS_URL=http://localhost:3001

# ── Server Config ────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── Timezone ─────────────────────────────────────────────────────
# Used for: Gemini quota reset (midnight), scheduler cron jobs
# Must be a valid IANA timezone identifier.
# Default: Asia/Kolkata (IST, UTC+5:30)
TIMEZONE=Asia/Kolkata
